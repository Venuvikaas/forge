# Copy to .env and fill in. NEVER commit .env.

# Model provider for the agents (e.g. Anthropic Claude)
MODEL_API_KEY=

# GitHub read-only Personal Access Token (scope: public_repo / repo:read)
GITHUB_PAT=
# Repo to ingest issues from, e.g. owner/name
GITHUB_REPO=

# Lemma pod connection (fill from your pod / `lemma` CLI setup)
LEMMA_POD_URL=
LEMMA_API_KEY=
