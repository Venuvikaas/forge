# Copy to .env and fill in. NEVER commit .env.

# --- Model provider for the agents (Day 2+) ---
# An Anthropic Claude API key for the triage / investigation agents.
MODEL_API_KEY=

# --- GitHub (read-only, for github_fetch) ---
# Personal Access Token, fine-grained or classic with read-only `public_repo`.
# Public repos work without a token too, but a PAT raises the rate limit.
GITHUB_PAT=
# Repo to ingest issues from, e.g. owner/name
GITHUB_REPO=

# --- Lemma pod connection (real lemma-sdk env vars) ---
# Easiest path: install the Lemma CLI and run `lemma auth login`, then set
# LEMMA_POD_ID below. The CLI writes a token to ~/.lemma/config.json that the
# SDK picks up automatically, so LEMMA_TOKEN can stay empty in that case.
# Otherwise, paste a token from the Lemma dashboard into LEMMA_TOKEN.
LEMMA_POD_ID=
LEMMA_TOKEN=
# Optional — defaults to https://api.lemma.work
LEMMA_BASE_URL=
# Optional — only for org-scoped operations
LEMMA_ORG_ID=
